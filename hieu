--- CHỨC NĂNG NOCLIP ---
local function ToggleNoclip()
    noclipActive = not noclipActive
    
    if noclipActive then
        -- Khi BẬT
        ToggleButton.Text = "Noclip: ON"
        TweenService:Create(ToggleButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 180, 0)}):Play() -- Chuyển xanh khi ON
        
        noclipConnection = RunService.Stepped:Connect(function()
            if LocalPlayer.Character then
                for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                    if part:IsA("BasePart") and part.CanCollide == true then
                        part.CanCollide = false
                    end
                end
            end
        end)
    else
        -- Khi TẮT
        ToggleButton.Text = "Noclip: OFF"
        TweenService:Create(ToggleButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(180, 0, 0)}):Play() -- Trả về màu đỏ
        
        if noclipConnection then
            noclipConnection:Disconnect()
        end
    end
end

ToggleButton.MouseButton1Click:Connect(ToggleNoclip)

